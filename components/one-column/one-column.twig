{#
/**
 * @file
 * Jarvis 1-column layout. Bootstrap row so it composes with the grid.
 */
#}
{% set space = [(padding is defined and padding != 'none') ? 'jp-p-' ~ padding ~ '-' ~ (padding_size|default('medium')) : '', (margin is defined and margin != 'none') ? 'jp-m-' ~ margin ~ '-' ~ (margin_size|default('medium')) : '', (vertical_padding|default(false)) ? 'jp-vpad' : '']|join(' ')|trim %}
{% set gap_class = { none: 'g-0', small: 'g-2', normal: 'g-4', large: 'g-5' }[gap|default('normal')] %}
{% set container = (width|default('boxed')) == 'full' ? 'container-fluid' : 'container' %}
<div class="jarvis-columns jarvis-columns--1 {{ space }}">
  <div class="{{ container }}">
    <div class="row {{ gap_class }}">
      <div class="col-12">
        {{ first }}
      </div>
    </div>
  </div>
</div>
