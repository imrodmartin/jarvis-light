{#
/**
 * @file
 * Local tasks (View / Edit / Revisions) as Bootstrap tabs.
 *
 * Primary tasks render as nav-tabs, secondary as nav-pills; the nav-link
 * classes on the links themselves come from jarvis_preprocess_menu_local_task().
 */
#}
{% if primary %}
  <h2 class="visually-hidden">{{ 'Primary tabs'|t }}</h2>
  <ul class="nav nav-tabs mb-3">{{ primary }}</ul>
{% endif %}
{% if secondary %}
  <h2 class="visually-hidden">{{ 'Secondary tabs'|t }}</h2>
  <ul class="nav nav-pills mb-3">{{ secondary }}</ul>
{% endif %}
